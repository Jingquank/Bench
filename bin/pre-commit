#!/usr/bin/env bash

# Bump the pack-wide version (package.json) whenever any shipped skill changes.
# package.json is the single source of truth for the version across all skills.
SKILL_FILES=$(git diff --cached --name-only | grep -E '^(XRAY\.md|DRILL\.md|REALITYCHECK\.md|LORE\.md)$')

if [ -z "$SKILL_FILES" ]; then
  exit 0
fi

PKG="package.json"

CURRENT=$(grep -m1 '"version":' "$PKG" | sed -E 's/.*"version":[[:space:]]*"([^"]+)".*/\1/')

if [ -z "$CURRENT" ]; then
  echo "bench: no version found in package.json — skipping bump"
  exit 0
fi

MAJOR=$(echo "$CURRENT" | cut -d. -f1)
MINOR=$(echo "$CURRENT" | cut -d. -f2)
PATCH=$(echo "$CURRENT" | cut -d. -f3)

NEW_PATCH=$((PATCH + 1))
NEW_VERSION="$MAJOR.$MINOR.$NEW_PATCH"

if [[ "$OSTYPE" == "darwin"* ]]; then
  sed -i '' "s/\"version\": \"$CURRENT\"/\"version\": \"$NEW_VERSION\"/" "$PKG"
else
  sed -i "s/\"version\": \"$CURRENT\"/\"version\": \"$NEW_VERSION\"/" "$PKG"
fi

git add "$PKG"

echo "bench: bumped to $NEW_VERSION"
